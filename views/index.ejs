<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <style>
        body { font-family: sans-serif; padding: 50px; text-align: center; }
        .btn { padding: 10px 20px; cursor: pointer; background: #007bff; color: white; border: none; border-radius: 5px; margin: 5px; }
        .btn-logout { background: #dc3545; }
        .error-message { color: red; padding: 10px; border: 1px solid red; margin: 20px auto; width: 300px; }
        input { padding: 10px; border-radius: 5px; border: 1px solid #ccc; width: 250px; }
    </style>
</head>
<body>

    <h1>Завдання 6: Валідація даних</h1>

    <% if (!isAuthenticated) { %>
        <!-- 1. СТАН: НЕ АВТОРИЗОВАНИЙ -->
        <p>Будь ласка, увійдіть, щоб додавати користувачів.</p>
        <form action="/login" method="POST">
            <button class="btn" type="submit">Увійти (Login)</button>
        </form>

    <% } else { %>
        
        <!-- 2. СТАН: АВТОРИЗОВАНИЙ -->
        <p style="color: green;">Ви в системі! Тепер спробуйте додати користувача.</p>

        <!-- === НОВИЙ БЛОК: ВИВЕДЕННЯ ПОМИЛОК ВАЛІДАЦІЇ === -->
        <% if (errorMessage) { %>
            <div class="error-message">
                <%= errorMessage %>
            </div>
        <% } %>

        <!-- ФОРМА ДОДАВАННЯ (ЯКУ МИ ВАЛІДУЄМО) -->
        <form action="/add-user" method="POST">
            <input 
                type="text" 
                name="username" 
                placeholder="Введіть мінімум 3 символи..."
                value="<%= oldInput.name %>" 
            >
            <button class="btn" type="submit">Додати</button>
        </form>

        <hr>
        <form action="/logout" method="POST">
            <button class="btn btn-logout" type="submit">Вийти (Logout)</button>
        </form>

    <% } %>

</body>
</html>